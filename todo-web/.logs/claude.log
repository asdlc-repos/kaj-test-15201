{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01RRB2kcVC6KB9kwHuncCoiV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YFRn3vyToA4W4t7qBcamjH","name":"Write","input":{"file_path":"/Users/kajendran/.asdlc/repos/default/kaj-test-15/todo-web/src/api.ts","content":"import { Category, CategoryInput, Task, TaskInput } from './types';\n\nconst BASE_URL = (import.meta.env.VITE_API_BASE_URL as string) || 'http://localhost:9090';\n\nasync function handleResponse<T>(res: Response): Promise<T> {\n  if (!res.ok) {\n    let message = `HTTP ${res.status}`;\n    try {\n      const data = await res.json();\n      message = data.error || message;\n    } catch {\n      // ignore\n    }\n    throw new Error(message);\n  }\n  if (res.status === 204) return undefined as unknown as T;\n  return res.json();\n}\n\nexport async function fetchCategories(): Promise<Category[]> {\n  const res = await fetch(`${BASE_URL}/categories`);\n  return handleResponse<Category[]>(res);\n}\n\nexport async function createCategory(input: CategoryInput): Promise<Category> {\n  const res = await fetch(`${BASE_URL}/categories`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(input),\n  });\n  return handleResponse<Category>(res);\n}\n\nexport async function updateCategory(id: string, input: CategoryInput): Promise<Category> {\n  const res = await fetch(`${BASE_URL}/categories/${id}`, {\n    method: 'PUT',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(input),\n  });\n  return handleResponse<Category>(res);\n}\n\nexport async function deleteCategory(id: string): Promise<void> {\n  const res = await fetch(`${BASE_URL}/categories/${id}`, { method: 'DELETE' });\n  return handleResponse<void>(res);\n}\n\nexport async function fetchTasks(categoryId?: string): Promise<Task[]> {\n  const url = categoryId\n    ? `${BASE_URL}/tasks?categoryId=${encodeURIComponent(categoryId)}`\n    : `${BASE_URL}/tasks`;\n  const res = await fetch(url);\n  return handleResponse<Task[]>(res);\n}\n\nexport async function createTask(input: TaskInput): Promise<Task> {\n  const res = await fetch(`${BASE_URL}/tasks`, {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(input),\n  });\n  return handleResponse<Task>(res);\n}\n\nexport async function updateTask(id: string, input: TaskInput): Promise<Task> {\n  const res = await fetch(`${BASE_URL}/tasks/${id}`, {\n    method: 'PUT',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(input),\n  });\n  return handleResponse<Task>(res);\n}\n\nexport async function deleteTask(id: string): Promise<void> {\n  const res = await fetch(`${BASE_URL}/tasks/${id}`, { method: 'DELETE' });\n  return handleResponse<void>(res);\n}\n\nexport async function toggleTaskCompletion(id: string, completed: boolean): Promise<Task> {\n  const res = await fetch(`${BASE_URL}/tasks/${id}/complete`, {\n    method: 'PATCH',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ completed }),\n  });\n  return handleResponse<Task>(res);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":287,"cache_read_input_tokens":24465,"cache_creation":{"ephemeral_5m_input_tokens":287,"ephemeral_1h_input_tokens":0},"output_tokens":60,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":"toolu_012SkThZ85sRPpQFbC9yCEuT","session_id":"0bcac202-cbc0-4f39-a1fe-0f8f308f7dc8","uuid":"45be3e5c-8f15-47cf-8c68-92fed3bbbd77"}
