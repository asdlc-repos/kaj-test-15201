{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019Pe317oQomYMFxR5SdJBHq","type":"tool_result","content":"1\t/**\n2\t * Returns true if the given YYYY-MM-DD date string is strictly before today (local time).\n3\t * Parses as local noon to avoid UTC/local timezone off-by-one errors.\n4\t */\n5\texport function isOverdue(dueDate: string | null, completed: boolean): boolean {\n6\t  if (!dueDate || completed) return false;\n7\t  // Parse as local noon to avoid timezone issues\n8\t  const [year, month, day] = dueDate.split('-').map(Number);\n9\t  const due = new Date(year, month - 1, day, 12, 0, 0);\n10\t  const today = new Date();\n11\t  today.setHours(12, 0, 0, 0);\n12\t  return due < today;\n13\t}\n14\t\n15\texport function formatDate(dueDate: string): string {\n16\t  const [year, month, day] = dueDate.split('-').map(Number);\n17\t  const d = new Date(year, month - 1, day);\n18\t  return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });\n19\t}\n20\t"}]},"parent_tool_use_id":null,"session_id":"0bcac202-cbc0-4f39-a1fe-0f8f308f7dc8","uuid":"ae595b49-7c0e-464e-be83-26bbd010c81b","timestamp":"2026-04-23T11:02:44.948Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kajendran/.asdlc/repos/default/kaj-test-15/todo-web/src/utils.ts","content":"/**\n * Returns true if the given YYYY-MM-DD date string is strictly before today (local time).\n * Parses as local noon to avoid UTC/local timezone off-by-one errors.\n */\nexport function isOverdue(dueDate: string | null, completed: boolean): boolean {\n  if (!dueDate || completed) return false;\n  // Parse as local noon to avoid timezone issues\n  const [year, month, day] = dueDate.split('-').map(Number);\n  const due = new Date(year, month - 1, day, 12, 0, 0);\n  const today = new Date();\n  today.setHours(12, 0, 0, 0);\n  return due < today;\n}\n\nexport function formatDate(dueDate: string): string {\n  const [year, month, day] = dueDate.split('-').map(Number);\n  const d = new Date(year, month - 1, day);\n  return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });\n}\n","numLines":20,"startLine":1,"totalLines":20}}}
